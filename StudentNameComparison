import java.util.Scanner;

public class StudentNameComparison {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Accept two student names
        System.out.print("Enter first student name: ");
        String name1 = scanner.nextLine();
        
        System.out.print("Enter second student name: ");
        String name2 = scanner.nextLine();

        // Case-sensitive comparison
        System.out.println("\n--- Case-Sensitive Comparison ---");
        if (name1.equals(name2)) {
            System.out.println("The names \"" + name1 + "\" and \"" + name2 + "\" are exactly the same.");
        } else {
            System.out.println("The names are different when considering letter case.");
        }

        // Case-insensitive comparison
        System.out.println("\n--- Case-Insensitive Comparison ---");
        if (name1.equalsIgnoreCase(name2)) {
            System.out.println("The names are the same (ignoring upper/lower case).");
        } else {
            System.out.println("The names are entirely different.");
        }

        scanner.close();
    }
}
